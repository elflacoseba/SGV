<input class="form-control" placeholder="Search tasks..." type="search"/>
<i class="ti ti-search app-search-icon text-muted"></i>
</div>
<!-- Filter Controls -->
<div class="d-flex flex-wrap align-items-center gap-2">
<!-- Department Filter -->
<div class="app-search">
<select class="form-select form-control">
<option selected="">Department</option>
<option value="Design">Design</option>
<option value="Development">Development</option>
<option value="UI/UX">UI/UX</option>
<option value="Marketing">Marketing</option>
<option value="Finance">Finance</option>
<option value="QA">QA</option>
</select>
<i class="ti ti-briefcase app-search-icon text-muted"></i>
</div>
<!-- Due Date Filter -->
<div class="app-search">
<select class="form-select form-control">
<option selected="">Due Date</option>
<option value="Today">Today</option>
<option value="This Week">This Week</option>
<option value="This Month">This Month</option>
</select>
<i class="ti ti-calendar-clock app-search-icon text-muted"></i>
</div>
</div>
<!-- Apply Filter Button -->
<button class="btn btn-secondary ms-lg-auto" type="submit">
<i class="ti ti-plus me-1"></i>
                                    Add New Card

<div class="text-end">
<h3 class="mb-2 fw-normal"><span data-target="50,895">0</span></h3>
<p class="mb-0 text-muted"><span>Monthly New Customers</span></p>
</div>
</div>
</div>
</div>
</div>
<!-- end col -->

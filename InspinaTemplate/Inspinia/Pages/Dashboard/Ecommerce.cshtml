@page "/dashboard/ecommerce"
@model Inspinia.Pages.Dashboard.EcommerceModel


@{
    ViewBag.title = "eCommerce";
    ViewBag.subtitle = "Dashboard";
}


@section Styles {
    <link href="/plugins/jsvectormap/jsvectormap.min.css" rel="stylesheet" type="text/css"/>
}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Main Content -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row row-cols-xxl-4 row-cols-md-2 row-cols-1">
<!-- Total Sales Widget -->
<div class="col">
<div class="card">
<div class="card-header d-flex border-dashed justify-content-between align-items-center">
<h5 class="card-title">Total Sales</h5>
<span class="badge badge-soft-success"> Monthly</span>
</div>
<div class="card-body">
<div class="d-flex justify-content-between align-items-center">
<div class="donut-chart" data-chart="donut" style="min-height: 60px; width: 60px"></div>
<div class="text-end">
<h3 class="mb-2 fw-normal">$<span data-target="250">0</span>K</h3>
<p class="mb-0 text-muted"><span>Monthly Total Sales</span></p>
</div>
</div>
</div>
</div>
</div>
<!-- end col -->
<!-- Total Orders Widget -->
<div class="col">
<div class="card">
<div class="card-header d-flex border-dashed justify-content-between align-items-center">

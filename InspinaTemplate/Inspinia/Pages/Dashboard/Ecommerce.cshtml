<div class="text-end">
<h3 class="mb-2 fw-normal"><span data-target="180">0</span></h3>
<p class="mb-0 text-muted"><span>Monthly Total Orders</span></p>
</div>
</div>
</div>
</div>
</div>
<!-- end col -->
<!-- New Customers Widget -->

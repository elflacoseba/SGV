@page "/charts/apex/mixed"
@model Inspinia.Pages.Charts.Apex.MixedModel


@{
    ViewBag.title = "Mixed Apexchart";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Page Content here -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Line &amp; Column Chart</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="line-column-mixed"></div>
</div>
</div>
</div>
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Multiple Y-Axis Chart</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="multiple-yaxis-mixed"></div>
</div>
</div>
</div>
</div>
<!-- end col-->
</div>
<!-- end row-->
<div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Line &amp; Area Chart</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="line-area-mixed"></div>
</div>
</div>
</div>
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Line, Column &amp; Area Chart</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="all-mixed"></div>
</div>
</div>
</div>
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End Page content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- Apex Chart js -->

<!-- Apex Chart Polar Area Demo js -->



@section Scripts {
<script src="/plugins/apexcharts/apexcharts.min.js"></script>
    <script src="/js/pages/chart-apex-mixed.js"></script>
}

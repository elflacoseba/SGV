@page "/charts/apex/heatmap"
@model Inspinia.Pages.Charts.Apex.HeatmapModel


@{
    ViewBag.title = "Heatmap Apexchart";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Page Content here -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Heatmap - Single Series</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="basic-heatmap"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Multiple Series</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="multiple-series-heatmap"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Heatmap - Color Range</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="color-range-heatmap"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Heatmap - Range without Shades</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="rounded-heatmap"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End Page content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- Apex Charts js -->

<!-- Apex Chart Pie Demo js -->



@section Scripts {
<script src="/plugins/apexcharts/apexcharts.min.js"></script>
    <script src="/js/pages/chart-apex-heatmap.js"></script>
}

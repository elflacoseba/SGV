@page "/charts/apex/range"
@model Inspinia.Pages.Charts.Apex.RangeModel


@{
    ViewBag.title = "Range Apexcharts";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Page Content here -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Basic Range Area</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="basic-range"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Range Area With Line</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="combo-range"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End Page content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- Apex Chart js -->

<!-- Moment js -->

<!-- Apex Chart Timeline Demo js -->



@section Scripts {
<script src="/plugins/apexcharts/apexcharts.min.js"></script>
    <script src="/plugins/moment/moment.min.js"></script>
    <script src="/js/pages/chart-apex-range.js"></script>
}

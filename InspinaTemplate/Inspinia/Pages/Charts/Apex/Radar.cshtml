@page "/charts/apex/radar"
@model Inspinia.Pages.Charts.Apex.RadarModel


@{
    ViewBag.title = "Radar Apexchart";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Page Content here -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Basic Radar Chart</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="basic-radar"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Radar with Polygon-fill</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="radar-polygon"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
<div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Radar – Multiple Series</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="radar-multiple-series"></div>
<div class="text-center mt-2">
<button class="btn btn-sm btn-primary" id="update-radar">Update</button>
</div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End Page content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- Apex Chart js -->

<!-- Apex Chart Polar Area Demo js -->



@section Scripts {
<script src="/plugins/apexcharts/apexcharts.min.js"></script>
    <script src="/js/pages/chart-apex-radar.js"></script>
}

@page "/charts/apex/candlestick"
@model Inspinia.Pages.Charts.Apex.CandlestickModel


@{
    ViewBag.title = "Candlestick Apexchart";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Page Content here -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Simple Candlestick Charts</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="simple-candlestick"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Combo Candlestick Charts</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="combo-candlestick"></div>
<div class="apex-charts" id="combo-bar-candlestick"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
<div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Category X-Axis</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="x-axis-candlestick"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title">Candlestick with Line</h4>
</div>
<div class="card-body">
<div dir="ltr">
<div class="apex-charts" id="candlestick-with-line"></div>
</div>
</div>
<!-- end card body-->
</div>
<!-- end card -->
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End Page content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- Apex Charts js -->

<!-- Apex Chart Candlestick Demo js -->


<!-- Apex Chart Area Demo js -->



@section Scripts {
<script src="/plugins/apexcharts/apexcharts.min.js"></script>
    <script src="https://apexcharts.com/samples/assets/ohlc.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dayjs/1.8.17/dayjs.min.js"></script>
    <script src="/js/pages/chart-apex-candlestick.js"></script>
}

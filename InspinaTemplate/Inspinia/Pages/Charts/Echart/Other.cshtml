@page "/charts/echart/other"
@model Inspinia.Pages.Charts.Echart.OtherModel


@{
    ViewBag.title = "Other Echart";
    ViewBag.subtitle = "Charts";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Main Content -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="row">
<div class="col-xl-6">
<div class="card">
<div class="card-header border-0">
<h4 class="card-title mb-0">Pictorialbar Dotted Chart</h4>
</div>
<div class="card-body p-2 pt-0">
<div class="rounded-3 overflow-hidden" id="echart-pictorialbar-dotted" style="min-height: 400px"></div>
</div>
</div>
<!-- end card -->
</div>
<!-- end col -->
<div class="col-xl-6">
<div class="card">
<div class="card-header">
<h4 class="card-title mb-0">Basic Sunburst Chart</h4>
</div>
<div class="card-body p-2 pt-0">
<div id="echar-basic-sunburst" style="min-height: 399px"></div>
</div>
</div>
<!-- end card -->
</div>
<!-- end col -->
<div class="col-xl-12">
<div class="card">
<div class="card-header">
<h4 class="card-title mb-0">Nested Pie Chart</h4>
</div>
<div class="card-body">
<div id="chart-pie-nest" style="min-height: 600px"></div>
</div>
</div>
<!-- end card -->
</div>
<!-- end col -->
</div>
<!-- end row -->
</div>
<!-- container -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End of Main Content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        <!-- E Charts js -->

<!-- E Charts Demo js -->



@section Scripts {
<script src="/plugins/echarts/echarts.min.js"></script>
    <script src="/js/pages/chart-echart-other.js"></script>
}

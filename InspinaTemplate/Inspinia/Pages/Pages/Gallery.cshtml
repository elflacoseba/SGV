@page "/pages/gallery"
@model Inspinia.Pages.Pages.GalleryModel


@{
    ViewBag.title = "Gallery";
    ViewBag.subtitle = "Miscellaneous";
}


@section Styles {
    <link href="/plugins/glightbox/glightbox.min.css" rel="stylesheet"/>
}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")


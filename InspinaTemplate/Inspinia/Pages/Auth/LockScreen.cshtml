@page "/auth/lock-screen"
@model Inspinia.Pages.Auth.LockScreenModel


@{
    ViewBag.title = "Lock Screen";
}


@section Styles {

}


<div class="auth-box overflow-hidden align-items-center d-flex">
<div class="container">
<div class="row justify-content-center">
<div class="col-xxl-4 col-md-6 col-sm-8">
<div class="auth-brand text-center mb-4">
<a class="logo-dark" href="/">
<img alt="dark logo" src="/images/logo-black.png"/>
</a>
<a class="logo-light" href="/">
<img alt="logo" src="/images/logo.png"/>
</a>
<h4 class="fw-bold mt-3">Lock Screen!</h4>
<p class="text-muted w-lg-75 mx-auto">This screen is locked. Enter your password to continue</p>
</div>
<div class="card p-4">
<div class="text-center mb-4">
<img alt="thumbnail" class="rounded-circle img-thumbnail avatar-xxl mb-2" src="/images/users/user-1.jpg"/>
<h5 class="fs-md">Damian D.</h5>
</div>
<form>
<div class="mb-3">
<label class="form-label" for="userPassword">
                                        Password
                                        <span class="text-danger">*</span>
</label>
<div class="input-group">
<input class="form-control" id="userPassword" placeholder="••••••••" required="" type="password"/>
</div>
</div>
<div class="d-grid">
<button class="btn btn-primary fw-semibold py-2" type="submit">Unlock</button>
</div>
</form>
<p class="text-muted text-center mt-4 mb-0">
                                Not you? Return to
                                <a class="text-decoration-underline link-offset-3 fw-semibold" href="/auth/sign-in">Sign in</a>
</p>
</div>
<p class="text-center text-muted mt-4 mb-0">
                            ©
                            <script>
                                document.write(new Date().getFullYear())
                            </script>
                            Inspinia — by
                            <span class="fw-bold">WebAppLayers</span>
</p>
</div>
</div>
</div>
</div>
<!-- end auth-fluid-->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")
    

@section Scripts {

}

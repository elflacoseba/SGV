@page "/plugins/live-favicon"
@model Inspinia.Pages.Plugins.LiveFaviconModel


@{
    ViewBag.title = "Live Favicon";
    ViewBag.subtitle = "Plugins";
}


@section Styles {

}


<!-- Begin page -->
<div class="wrapper">
            @await Html.PartialAsync("~/Pages/Shared/Partials/_Topbar.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_Sidenav.cshtml")

            <!-- ============================================================== -->
<!-- Start Main Content -->
<!-- ============================================================== -->
<div class="content-page">
<div class="container-fluid">
                    @await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

                    <div class="container">
<div class="row">
<div class="col-lg-12">
<div class="card">
<div class="card-header">
<h5 class="card-title">Favicon Notification (Tinycon Alternative)</h5>
<div class="card-action">
<a class="card-action-item" data-action="card-toggle" href="/#!">
<i class="ti ti-chevron-up align-middle"></i>
</a>
<a class="card-action-item" data-action="code-collapse" href="/#!">
<i class="ti ti-code align-middle"></i>
</a>
</div>
</div>
<div class="code-body">
<pre>
                    <code class="language-javascript">
                    // Set the badge number
                    Tinycon.setBubble(6);
                    
                    // Customize appearance
                    Tinycon.setOptions({
                        width: 7,
                        height: 9,
                        font: '10px Arial',
                        colour: '#ffffff',
                        background: '#549A2F',
                        fallback: true
                    });
                    </code>
                                    </pre>
</div>
<div class="card-body">
<strong>Display Notifications on Favicon</strong>
<p class="mt-2">Tinycon is a small library that lets you add dynamic notifications to the browser tab favicon. You can show badge counts, change icon colors, and provide visual alerts when the user’s attention is needed.</p>
<p>For browsers that don’t support canvas or dynamic favicons, Tinycon automatically falls back to updating the document title with a count.</p>
<div class="text-center p-3">
<a class="btn btn-light" href="/#" id="iconExample1">Set Icon to 1</a>
<a class="btn btn-light" href="/#" id="iconExample2">Set Icon to 1000</a>
<a class="btn btn-light" href="/#" id="iconExample3">Set Icon to "In"</a>
<a class="btn btn-primary" href="/#" id="iconExample4">Set Icon with Custom Color</a>
</div>
<h4>Options</h4>
<p>Tinycon supports the following customization options:</p>
<ul>
<li>
<strong>width</strong>
                                                : Width of the badge bubble
                                            </li>
<li>
<strong>height</strong>
                                                : Height of the badge bubble
                                            </li>
<li>
<strong>font</strong>
                                                : CSS font style for the badge text
                                            </li>
<li>
<strong>colour</strong>
                                                : Text color inside the badge
                                            </li>
<li>
<strong>background</strong>
                                                : Background color of the badge
                                            </li>
<li>
<strong>fallback</strong>
                                                : Show count in page title if favicon updates aren't supported
                                            </li>
<li>
<strong>abbreviate</strong>
                                                : Shorten large numbers (e.g., 1000 → 1k)
                                            </li>
</ul>
</div>
<!-- end card-body-->
</div>
<!-- end card-->
</div>
<!-- end col-->
</div>
<!-- end row-->
</div>
<!-- end container-->
</div>
<!-- container-fluid -->

                @await Html.PartialAsync("~/Pages/Shared/Partials/_Footer.cshtml")
            </div>
<!-- ============================================================== -->
<!-- End of Main Content -->
<!-- ============================================================== -->
</div>
<!-- END wrapper -->

        @await Html.PartialAsync("~/Pages/Shared/Partials/_Customizer.cshtml") @await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

        



@section Scripts {
<script src="/plugins/tinycon/tinycon.min.js"></script>
    <script src="/js/pages/plugins-tinycon.js"></script>
}

@page "/organizacion/unidades-organizativas/organigrama"
@model SGV.Web.Pages.Organizacion.UnidadesOrganizativas.OrganigramaModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewBag.title = "Organigrama";
    ViewBag.subtitle = "Organización";
}

@await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title mb-1">Organigrama de unidades organizativas</h4>
                <p class="text-muted mb-0">Explorá la jerarquía organizativa y navegá a los detalles de cada nodo.</p>
            </div>
            <div class="card-body">
                @if (Model.TreeItems.Count == 0 && string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
                {
                    <div class="text-center text-muted py-4">
                        <p class="mb-0">No hay unidades organizativas para mostrar en el organigrama.</p>
                        <a class="btn btn-outline-primary btn-sm mt-3" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index")">Volver al listado</a>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
                {
                    <div class="text-center text-muted py-4">
                        <a class="btn btn-outline-primary btn-sm" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index")">Volver al listado</a>
                    </div>
                }
                else
                {
                    <div id="orgchart" style="width:100%; min-height:500px; overflow:auto;"></div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    window.__sgvApiBaseUrl = '@(Configuration["SgvApi:BaseUrl"] ?? $"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}")';
</script>

@section scripts {
    <script src="https://www.gstatic.com/charts/loader.js"></script>
    <script src="/js/pages/organigrama.js"></script>
}

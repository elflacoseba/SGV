@page "/organizacion/unidades-organizativas/crear"
@model SGV.Web.Pages.Organizacion.UnidadesOrganizativas.CreateModel

@{
    ViewBag.title = "Crear unidad organizativa";
    ViewBag.subtitle = "Organización";
}

@await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
}

<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Nueva unidad organizativa</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnPage" />
                    <input type="hidden" asp-for="ReturnSearch" />
                    <input type="hidden" asp-for="ReturnSort" />
                    <input type="hidden" asp-for="ReturnView" />

                    @await Html.PartialAsync("_Form", Model)

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a class="btn btn-light" href="@Model.ReturnToListUrl">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@page "/organizacion/unidades-organizativas"
@model SGV.Web.Pages.Organizacion.UnidadesOrganizativas.IndexModel

@{
    ViewBag.title = "Unidades Organizativas";
    ViewBag.subtitle = "Organización";
}

@section styles {
    <link rel="stylesheet" href="/plugins/sweetalert2/sweetalert2.min.css" />
}

@await Html.PartialAsync("~/Pages/Shared/Partials/_PageTitle.cshtml")

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-@Model.StatusKind" role="alert">@Model.StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
}

<div class="row">
    <div class="col-12">
        <div class="card" data-table>
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h4 class="card-title mb-1">Listado de unidades organizativas</h4>
                    <p class="text-muted mb-0">Consulta, búsqueda y eliminación del primer módulo funcional del shell.</p>
                </div>
                <span class="badge badge-soft-primary fs-xs">@Model.TotalCount registro(s)</span>
            </div>
            <div class="card-header border-0">
                <form class="row g-2 align-items-center w-100" method="get">
                    <div class="col-md-6 col-xl-4">
                        <div class="app-search">
                            <input class="form-control" name="search" placeholder="Buscar..." data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="Buscar por código o nombre..." type="search" value="@Model.Search" />
                            <i class="ti ti-search app-search-icon text-muted"></i>
                        </div>
                    </div>
                    <input name="sort" type="hidden" value="@Model.Sort" />
                    <div class="col-auto">
                        <button class="btn btn-primary" type="submit">Buscar</button>
                    </div>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-custom table-centered table-hover w-100 mb-0">
                    <thead class="bg-light align-middle bg-opacity-25 thead-sm">
                        <tr class="text-uppercase fs-xxs">
                            <th>
                                <a class="link-reset" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = Model.CurrentPage, search = Model.Search, sort = Model.GetSortRoute("codigo") })">Código</a>
                            </th>
                            <th>
                                <a class="link-reset" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = Model.CurrentPage, search = Model.Search, sort = Model.GetSortRoute("nombre") })">Nombre</a>
                            </th>
                            <th>
                                <a class="link-reset" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = Model.CurrentPage, search = Model.Search, sort = Model.GetSortRoute("tipo") })">Tipo</a>
                            </th>
                            <th>Vigencia</th>
                            <th class="text-center" style="width: 1%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td class="text-center text-muted py-4" colspan="5">No se encontraron unidades organizativas.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Codigo</td>
                                    <td>
                                        <div>
                                            <div class="fw-medium">@item.Nombre</div>
                                            @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                            {
                                                <div class="text-muted fs-xs">@item.Descripcion</div>
                                            }
                                        </div>
                                    </td>
                                    <td><span class="badge badge-soft-secondary fs-xs">@item.Tipo</span></td>
                                    <td>@item.Vigencia</td>
                                    <td>
                                        <form class="d-flex justify-content-center" data-uo-delete-form method="post">
                                            @Html.AntiForgeryToken()
                                            <input name="id" type="hidden" value="@item.Id" />
                                            <input name="page" type="hidden" value="@Model.CurrentPage" />
                                            <input name="search" type="hidden" value="@Model.Search" />
                                            <input name="sort" type="hidden" value="@Model.Sort" />
                                            <button aria-label="Eliminar @item.Nombre" class="btn btn-light btn-icon btn-sm rounded-circle" data-uo-delete-button data-uo-item-name="@item.Nombre" formaction="?handler=Delete" type="submit">
                                                <i class="ti ti-trash fs-lg"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer d-flex flex-wrap justify-content-between align-items-center gap-3">
                <span class="text-muted">Página @Model.CurrentPage de @Model.TotalPages</span>
                <nav aria-label="Paginación de unidades organizativas">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : null)">
                            <a class="page-link" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = Model.CurrentPage - 1, search = Model.Search, sort = Model.Sort })">Anterior</a>
                        </li>
                        @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : null)">
                                <a class="page-link" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = pageNumber, search = Model.Search, sort = Model.Sort })">@pageNumber</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : null)">
                            <a class="page-link" href="@Url.Page("/Organizacion/UnidadesOrganizativas/Index", new { page = Model.CurrentPage + 1, search = Model.Search, sort = Model.Sort })">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="/plugins/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="/js/pages/unidades-organizativas-index.js"></script>
}

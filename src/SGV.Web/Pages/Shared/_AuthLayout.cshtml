<!DOCTYPE html>
@{
    var html_attributes = ViewBag.HTMLAttributes ?? "";
    var html_class = ViewBag.HTMLClass ?? "";
    var body_class = ViewBag.BodyClass ?? "auth-body";
}
<html lang="en" @html_attributes class="@html_class">

<head>
    @await Html.PartialAsync("~/Pages/Shared/Partials/_TitleMeta.cshtml")

    @RenderSection("styles", false)

    @await Html.PartialAsync("~/Pages/Shared/Partials/_HeadCss.cshtml")
</head>

<body class="@body_class">

@RenderBody()

@await Html.PartialAsync("~/Pages/Shared/Partials/_FooterScripts.cshtml")

@RenderSection("scripts", required: false)

</body>
</html>
